generator client {
  provider = "prisma-client-js"
}

// need to - npm i @prisma/client
// rerun npx prisma generate

datasource db {
  provider = "postgresql"
}

enum Role {
  Employee
  DepartmentHead
  Hr
  Admin
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique()
  password  String
  email     String   @unique()
  role      Role
  profile   Profile?
  companyId Int
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Profile {
  id            Int    @id @default(autoincrement())
  firstname     String
  lastname      String
  age           Int
  address       String
  contactNumber String

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])
}

model Company {
  id          Int    @id @default(autoincrement())
  companyName String @unique
  description String
  user        User[]
}
