generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  Employee
  Supervisor
  Manager
  HR
}

model User {
  id       Int      @id @default(autoincrement())
  username String   @unique()
  password String
  email    String   @unique()
  role     Role
  profile  Profile?
}

model Profile {
  id            Int    @id @default(autoincrement())
  firstname     String
  lastname      String
  age           Int
  address       String
  contactNumber Int

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])
}
