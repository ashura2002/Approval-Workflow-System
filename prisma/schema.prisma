generator client {
  provider = "prisma-client-js"
}

// need to - npm i @prisma/client
// rerun npx prisma generate

datasource db {
  provider = "postgresql"
}

model Role {
  id        Int     @id @default(autoincrement())
  name      String
  users     User[]
  companyId Int
  company   Company @relation(fields: [companyId], references: [id])
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique()
  password  String
  email     String   @unique()
  role      Role     @relation(fields: [roleId], references: [id])
  roleId    Int
  profile   Profile?
  company   Company  @relation(fields: [companyId], references: [id])
  companyId Int
}

model Profile {
  id            Int    @id @default(autoincrement())
  firstname     String
  lastname      String
  age           Int
  address       String
  contactNumber String

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])
}

model Company {
  id          Int    @id @default(autoincrement())
  companyName String @unique
  description String
  users       User[]
  roles       Role[]
}
