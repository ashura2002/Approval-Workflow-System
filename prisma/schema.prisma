generator client {
  provider = "prisma-client-js"
}

// need to - npm i @prisma/client
// rerun npx prisma generate

datasource db {
  provider = "postgresql"
}

enum Role {
  Admin
  HR
  DepartmentHead
  Employee
}

enum LeaveType {
  SickLeave
  EmergencyLeave
  PersonalLeave
  Others
}

enum RequestStatus {
  Pending
  Approved
  Rejected
}

model User {
  id        Int       @id @default(autoincrement())
  username  String    @unique()
  password  String
  email     String    @unique()
  profile   Profile?
  role      Role      @default(Employee)
  company   Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId Int?
  requests  Request[]
}

model Profile {
  id            Int    @id @default(autoincrement())
  firstname     String
  lastname      String
  age           Int
  address       String
  contactNumber String

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Company {
  id          Int    @id @default(autoincrement())
  companyName String @unique
  description String
  user        User[]
}

model Request {
  id        Int           @id @default(autoincrement())
  leaveType LeaveType
  startDate DateTime
  endDate   DateTime
  reason    String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  status    RequestStatus @default(Pending)
  userId    Int
  user      User          @relation(fields: [userId], references: [id])
}
